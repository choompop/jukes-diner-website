# Juke's Dashboard - Local Development Environment Template
# Copy this file to .env.local for local development
# DO NOT commit .env.local to version control

# ==============================================================================
# DEVELOPMENT MODE (Local Only)
# ==============================================================================

# Environment mode (use 'development' for local work)
NODE_ENV=development

# Dashboard auth - DEVELOPMENT MODE
# For local development, you can use plaintext passwords for convenience
DASHBOARD_ADMIN_USERNAME=admin
DASHBOARD_ADMIN_PASSWORD=test123

# Session signing secret (use any value for local dev, generate secure one for production)
DASHBOARD_AUTH_SECRET=local-dev-secret-key-for-session-signing-change-in-production

# ==============================================================================
# EXTERNAL INTEGRATIONS (Optional - fill when testing integrations locally)
# ==============================================================================

# Stripe test keys (get from Stripe Dashboard → Developers → API keys → Test mode)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Connect account IDs (optional - for testing multi-location features)
# STRIPE_ACCOUNT_EVENT_TRUCK=acct_...
# STRIPE_ACCOUNT_TRAILER_PARK=acct_...
# STRIPE_ACCOUNT_EAST_NASHVILLE=acct_...
# STRIPE_ACCOUNT_CORPORATE=acct_...

# Supabase (if testing database features)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=your-service-role-key

# OpenAI (if testing AI chat features)
# OPENAI_API_KEY=sk-...

# ==============================================================================
# NOTES
# ==============================================================================

# ⚠️  IMPORTANT: This is for LOCAL DEVELOPMENT ONLY
# - Plaintext passwords (DASHBOARD_ADMIN_PASSWORD) are ONLY allowed when NODE_ENV != 'production'
# - For production deployment, see .env.production.example
# - Never commit secrets to git - .env.local is gitignored

# 📝 For production deployment instructions, see:
# - docs/DASHBOARD_AUTH_MIGRATION.md
# - DEPLOYMENT-CHECKLIST.md
# - .env.production.example
