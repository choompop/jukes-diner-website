    {
      "tag": "food-proof",
      "output": "Instagram carousel",
      "prompt": "Turn approved food photos into a craveable menu/story post with a catering CTA."
    },
    {
      "tag": "catering-conversion",
      "output": "Website proof block",
      "prompt": "Create a trust-building event recap with headcount, service style, and booking CTA."
    },
    {
      "tag": "build-in-public",
      "output": "TikTok script",
      "prompt": "Cut a raw founder/operator lesson with hook, conflict, system, and lesson."
    },
    {
