# Juke's Dashboard - Production Environment Template
# Copy this file to .env and fill in the values
# DO NOT commit .env or .env.local to version control

# ==============================================================================
# REQUIRED FOR PRODUCTION
# ==============================================================================

# Environment mode (MUST be 'production' for deployment)
NODE_ENV=production

# Session signing secret (generate with: openssl rand -base64 32)
# CRITICAL: Use a unique, random secret for each environment
DASHBOARD_AUTH_SECRET=

# Dashboard admin credentials (choose ONE approach below)

# Option 1: Single Admin User (recommended for initial deployment)
# Generate hash with: node scripts/hash-dashboard-password.mjs --stdin
# Or for dev/testing: node scripts/hash-dashboard-password.mjs "your-password"
DASHBOARD_ADMIN_USERNAME=owner
DASHBOARD_ADMIN_PASSWORD_HASH=

# Option 2: Multiple Admin Users (JSON array)
# Each user needs a hash generated with their username as salt:
# node scripts/hash-dashboard-password.mjs "password" "username-salt"
# DASHBOARD_ADMIN_USERS=[{"username":"john","passwordHash":"...","role":"admin"},{"username":"tyler","passwordHash":"...","role":"admin"}]

# ==============================================================================
# RECOMMENDED FOR PRODUCTION
# ==============================================================================

# Internal API key for server-to-server calls (generate with: openssl rand -hex 32)
DASHBOARD_INTERNAL_API_KEY=

# ==============================================================================
# EXTERNAL INTEGRATIONS (Optional - set when needed)
# ==============================================================================

# Supabase (if using database features)
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_KEY=

# OpenAI (if using AI chat features)
# OPENAI_API_KEY=

# Stripe (if using payment features)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Connect account IDs (if managing multiple locations)
# STRIPE_ACCOUNT_EVENT_TRUCK=
# STRIPE_ACCOUNT_TRAILER_PARK=
# STRIPE_ACCOUNT_EAST_NASHVILLE=
# STRIPE_ACCOUNT_CORPORATE=

# ==============================================================================
# SECURITY NOTES
# ==============================================================================

# ✅ DO:
# - Use strong, unique secrets for each environment
# - Store secrets in your deployment platform's environment variables
# - Rotate secrets regularly (quarterly recommended)
# - Use a password manager to track secrets
#
# ❌ DO NOT:
# - Commit secrets to git (check .gitignore includes .env*)
# - Reuse secrets across dev/staging/production
# - Use weak or guessable passwords
# - Share credentials via email or chat
